# Keep text files consistent across Windows, Linux, and CI environments
* text=auto eol=lf

# Explicit text formats
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary